<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Fond dégradé radial de violet/indigo vers le noir profond -->
    <path
        android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76"
                android:type="radial">
                <item
                    android:color="#24143D"
                    android:offset="0.0" />
                <item
                    android:color="#0A0612"
                    android:offset="0.7" />
                <item
                    android:color="#050308"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Fines lignes de grille circulaires concentriques (esprit mental/Rorschach) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 54 54 m -24, 0 a 24,24 0 1,1 48,0 a 24,24 0 1,1 -48,0"
        android:strokeWidth="0.4"
        android:strokeColor="#1EFFFFFF" />
    <path
        android:fillColor="#00000000"
        android:pathData="M 54 54 m -40, 0 a 40,40 0 1,1 80,0 a 40,40 0 1,1 -80,0"
        android:strokeWidth="0.4"
        android:strokeColor="#0DFFFFFF" />

    <!-- Lignes d'axes diagonales subtiles -->
    <path
        android:fillColor="#00000000"
        android:pathData="M0,0 L108,108"
        android:strokeWidth="0.3"
        android:strokeColor="#0AFFFFFF" />
    <path
        android:fillColor="#00000000"
        android:pathData="M108,0 L0,108"
        android:strokeWidth="0.3"
        android:strokeColor="#0AFFFFFF" />
</vector>
